# -------------------------------------------------------------
# TierLive Engine Environment Configuration
# Copy this file to '.env' and fill in your values
# -------------------------------------------------------------

# Server Port (Default: 3001)
PORT=3001

# Public Server Domain / IP (Used for Webhooks, Nightbot URLs & QR codes)
PUBLIC_URL=http://localhost:3001

# Node Environment ('development' or 'production')
NODE_ENV=production

# Optional HTTP Webhook Security Secret (If set, incoming webhooks require X-Webhook-Secret header)
WEBHOOK_SECRET=my_custom_webhook_secret_key

# -------------------------------------------------------------
# Discord Bot Integration (Discord Developer Portal)
# -------------------------------------------------------------
# Get token at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Default Channel Webhook for Outgoing S-Tier / F-Tier Alert Notifications
DISCORD_WEBHOOK_URL=
